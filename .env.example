# ──────────────────────────────────────────────────────────────────────────
# Kickback AI — environment template. Canonical var names; the code reads these.
# Copy to .env and put REAL values there. .env is gitignored — never commit keys.
# Source of truth for these names: sdk-and-env-reference.md (§.env.example).
# ──────────────────────────────────────────────────────────────────────────

# Model for the harness itself
ANTHROPIC_API_KEY=

# Arc testnet
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000  # settlement/pool token ERC-20.
                                 # Mainnet USDC = this (6 dec). On arc-testnet the Unlink pool
                                 # token is ULNKMock 0x4F592595Ec2dcb794d949551554436807565b300.
ARC_USDC_DECIMALS=6              # decimals of ARC_USDC_ADDRESS. 6 for USDC; set 18 for ULNKMock.
PAYER_ADDRESS=                   # plain EOA, funded from faucet.circle.com (also the treasury below)
PAYER_PRIVATE_KEY=               # EOA key for Gateway x402 payments + Unlink pool deposits
# TREASURY_ADDRESS=              # EOA advertisers pay their public budget into. Defaults to PAYER_ADDRESS.
# FUND_MIN_CONFIRMATIONS=1       # confirmations required on the advertiser payment tx (raise for mainnet)
# SETTLEMENT_MODE=mock           # 'mock' (default, no chain) | 'real' (Unlink deposit/withdraw on Arc)

# Dynamic (app.dynamic.xyz → Developer tab)
DYNAMIC_ENVIRONMENT_ID=          # SDK & API Keys section (public)
DYNAMIC_SERVER_API_KEY=          # API Token → Create Token (dyn_..., shown once)
# DYNAMIC_USER_ID=               # OPTIONAL: Dynamic JWT `sub`, reused as the Unlink userId.
                                 # Comes from the deferred browser sign-in; until then the
                                 # payer EOA address stands in (see RealWalletProvider).
# DYNAMIC_DELEGATION_WEBHOOK_URL= # ONLY if doing delegated access (prize polish)

# Unlink (docs.unlink.xyz/quickstart#create-an-api-key)
UNLINK_ENVIRONMENT=arc-testnet
UNLINK_API_KEY=                  # backend only
# UNLINK_ENGINE_URL=             # OPTIONAL escape hatch: required when UNLINK_ENVIRONMENT is
                                 # not a built-in SDK env. "arc-testnet" is NOT built into
                                 # canary 0.3.0-canary.552 — set a verified Arc Engine URL here
                                 # to enable the REAL privacy provider (else it falls back to mock).
# UNLINK_MNEMONIC=               # OPTIONAL: BIP-39 seed for the user's private Unlink account.
                                 # Normally derived from the Dynamic embedded wallet (browser,
                                 # deferred); absent → mock privacy provider.
